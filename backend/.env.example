PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio
JWT_SECRET=replace_with_32_plus_char_random_string
JWT_EXPIRES_IN=1d
COOKIE_SECRET=replace_with_another_32_plus_char_random_string
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Seed script credentials (only needed when running npm run seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=replace_with_strong_password
